{
  "manifest_version": 3,
  "name": "YouTube Lite Guard",
  "version": "0.1.0",
  "description": "Reduce YouTube page weight with toggles for chat, comments, recommendations, Shorts, and other heavy sections.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "YouTube Lite Guard",
    "default_popup": "popup.html"
  }
}
